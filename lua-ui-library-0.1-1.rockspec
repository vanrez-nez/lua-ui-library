package = "lua-ui-library"
version = "0.1-1"
source = {
   url = "git+https://github.com/vanrez-nez/lua-ui-library.git"
}
description = {
   summary = "Standalone LÖVE project for the extracted `lib/ui` package from `idle-game`.",
   detailed = "Standalone LÖVE project for the extracted `lib/ui` package from `idle-game`.",
   homepage = "https://github.com/vanrez-nez/lua-ui-library",
   license = "UNLICENSED"
}
dependencies = {
   "lua ~> 5.1"
}
build_dependencies = {
   "luacheck"
}
build = {
   type = "builtin",
   modules = {
      ["cls.cls"] = "lib/cls/cls.lua",
      ["cls.init"] = "lib/cls/init.lua",
      ["ui.controls.alert"] = "lib/ui/controls/alert.lua",
      ["ui.controls.button"] = "lib/ui/controls/button.lua",
      ["ui.controls.checkbox"] = "lib/ui/controls/checkbox.lua",
      ["ui.controls.control_utils"] = "lib/ui/controls/control_utils.lua",
      ["ui.controls.modal"] = "lib/ui/controls/modal.lua",
      ["ui.controls.notification"] = "lib/ui/controls/notification.lua",
      ["ui.controls.option"] = "lib/ui/controls/option.lua",
      ["ui.controls.progress_bar"] = "lib/ui/controls/progress_bar.lua",
      ["ui.controls.radio"] = "lib/ui/controls/radio.lua",
      ["ui.controls.radio_group"] = "lib/ui/controls/radio_group.lua",
      ["ui.controls.select"] = "lib/ui/controls/select.lua",
      ["ui.controls.slider"] = "lib/ui/controls/slider.lua",
      ["ui.controls.switch"] = "lib/ui/controls/switch.lua",
      ["ui.controls.tabs"] = "lib/ui/controls/tabs.lua",
      ["ui.controls.text"] = "lib/ui/controls/text.lua",
      ["ui.controls.text_area"] = "lib/ui/controls/text_area.lua",
      ["ui.controls.text_input"] = "lib/ui/controls/text_input.lua",
      ["ui.controls.tooltip"] = "lib/ui/controls/tooltip.lua",
      ["ui.core.container"] = "lib/ui/core/container.lua",
      ["ui.core.container_property_views"] = "lib/ui/core/container_property_views.lua",
      ["ui.core.container_schema"] = "lib/ui/core/container_schema.lua",
      ["ui.core.corner_quad"] = "lib/ui/core/corner_quad.lua",
      ["ui.core.drawable"] = "lib/ui/core/drawable.lua",
      ["ui.core.drawable_schema"] = "lib/ui/core/drawable_schema.lua",
      ["ui.core.easing"] = "lib/ui/core/easing.lua",
      ["ui.core.insets"] = "lib/ui/core/insets.lua",
      ["ui.core.rectangle"] = "lib/ui/core/rectangle.lua",
      ["ui.core.responsive_breakpoints_gate"] = "lib/ui/core/responsive_breakpoints_gate.lua",
      ["ui.core.shape"] = "lib/ui/core/shape.lua",
      ["ui.core.shape_schema"] = "lib/ui/core/shape_schema.lua",
      ["ui.core.side_quad"] = "lib/ui/core/side_quad.lua",
      ["ui.core.spacing_schema"] = "lib/ui/core/spacing_schema.lua",
      ["ui.event.event"] = "lib/ui/event/event.lua",
      ["ui.event.event_dispatcher"] = "lib/ui/event/event_dispatcher.lua",
      ["ui.graphics.atlas"] = "lib/ui/graphics/atlas.lua",
      ["ui.graphics.image"] = "lib/ui/graphics/image.lua",
      ["ui.graphics.sprite"] = "lib/ui/graphics/sprite.lua",
      ["ui.graphics.texture"] = "lib/ui/graphics/texture.lua",
      ["ui.init"] = "lib/ui/init.lua",
      ["ui.layout.column"] = "lib/ui/layout/column.lua",
      ["ui.layout.column_schema"] = "lib/ui/layout/column_schema.lua",
      ["ui.layout.content_fill_guard"] = "lib/ui/layout/content_fill_guard.lua",
      ["ui.layout.direction"] = "lib/ui/layout/direction.lua",
      ["ui.layout.flow"] = "lib/ui/layout/flow.lua",
      ["ui.layout.flow_schema"] = "lib/ui/layout/flow_schema.lua",
      ["ui.layout.layout_node"] = "lib/ui/layout/layout_node.lua",
      ["ui.layout.layout_node_schema"] = "lib/ui/layout/layout_node_schema.lua",
      ["ui.layout.responsive"] = "lib/ui/layout/responsive.lua",
      ["ui.layout.row"] = "lib/ui/layout/row.lua",
      ["ui.layout.row_schema"] = "lib/ui/layout/row_schema.lua",
      ["ui.layout.safe_area_container"] = "lib/ui/layout/safe_area_container.lua",
      ["ui.layout.safe_area_container_schema"] = "lib/ui/layout/safe_area_container_schema.lua",
      ["ui.layout.sequential_layout"] = "lib/ui/layout/sequential_layout.lua",
      ["ui.layout.spacing"] = "lib/ui/layout/spacing.lua",
      ["ui.layout.stack"] = "lib/ui/layout/stack.lua",
      ["ui.layout.stack_schema"] = "lib/ui/layout/stack_schema.lua",
      ["ui.motion.init"] = "lib/ui/motion/init.lua",
      ["ui.motion.runtime"] = "lib/ui/motion/runtime.lua",
      ["ui.render.canvas_pool"] = "lib/ui/render/canvas_pool.lua",
      ["ui.render.canvas_pool_registry"] = "lib/ui/render/canvas_pool_registry.lua",
      ["ui.render.color"] = "lib/ui/render/color.lua",
      ["ui.render.graphics_source"] = "lib/ui/render/graphics_source.lua",
      ["ui.render.graphics_state"] = "lib/ui/render/graphics_state.lua",
      ["ui.render.graphics_stencil"] = "lib/ui/render/graphics_stencil.lua",
      ["ui.render.graphics_validation"] = "lib/ui/render/graphics_validation.lua",
      ["ui.render.nine_slice"] = "lib/ui/render/nine_slice.lua",
      ["ui.render.root_compositor"] = "lib/ui/render/root_compositor.lua",
      ["ui.render.source_placement"] = "lib/ui/render/source_placement.lua",
      ["ui.render.styling"] = "lib/ui/render/styling.lua",
      ["ui.render.styling_contract"] = "lib/ui/render/styling_contract.lua",
      ["ui.scene.composer"] = "lib/ui/scene/composer.lua",
      ["ui.scene.composer_schema"] = "lib/ui/scene/composer_schema.lua",
      ["ui.scene.scene"] = "lib/ui/scene/scene.lua",
      ["ui.scene.stage"] = "lib/ui/scene/stage.lua",
      ["ui.scene.stage_schema"] = "lib/ui/scene/stage_schema.lua",
      ["ui.scene.transitions"] = "lib/ui/scene/transitions.lua",
      ["ui.scroll.scrollable_container"] = "lib/ui/scroll/scrollable_container.lua",
      ["ui.scroll.scrollable_container_schema"] = "lib/ui/scroll/scrollable_container_schema.lua",
      ["ui.shapes.circle_shape"] = "lib/ui/shapes/circle_shape.lua",
      ["ui.shapes.diamond_shape"] = "lib/ui/shapes/diamond_shape.lua",
      ["ui.shapes.draw_helpers"] = "lib/ui/shapes/draw_helpers.lua",
      ["ui.shapes.fill_placement"] = "lib/ui/shapes/fill_placement.lua",
      ["ui.shapes.fill_renderer"] = "lib/ui/shapes/fill_renderer.lua",
      ["ui.shapes.fill_source"] = "lib/ui/shapes/fill_source.lua",
      ["ui.shapes.rect_shape"] = "lib/ui/shapes/rect_shape.lua",
      ["ui.shapes.triangle_shape"] = "lib/ui/shapes/triangle_shape.lua",
      ["ui.text.font_cache"] = "lib/ui/text/font_cache.lua",
      ["ui.themes.default"] = "lib/ui/themes/default.lua",
      ["ui.themes.resolver"] = "lib/ui/themes/resolver.lua",
      ["ui.themes.runtime"] = "lib/ui/themes/runtime.lua",
      ["ui.themes.theme"] = "lib/ui/themes/theme.lua",
      ["ui.utils.assert"] = "lib/ui/utils/assert.lua",
      ["ui.utils.common"] = "lib/ui/utils/common.lua",
      ["ui.utils.dirty_props"] = "lib/ui/utils/dirty_props.lua",
      ["ui.utils.env"] = "lib/ui/utils/env.lua",
      ["ui.utils.math"] = "lib/ui/utils/math.lua",
      ["ui.utils.matrix"] = "lib/ui/utils/matrix.lua",
      ["ui.utils.memoize"] = "lib/ui/utils/memoize.lua",
      ["ui.utils.reactive"] = "lib/ui/utils/reactive.lua",
      ["ui.utils.rule"] = "lib/ui/utils/rule.lua",
      ["ui.utils.schema"] = "lib/ui/utils/schema.lua",
      ["ui.utils.styling"] = "lib/ui/utils/styling.lua",
      ["ui.utils.types"] = "lib/ui/utils/types.lua",
      ["ui.utils.vec2"] = "lib/ui/utils/vec2.lua"
   },
   copy_directories = {
      "docs"
   }
}
test_dependencies = {
   "luaunit"
}
