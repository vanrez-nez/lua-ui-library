{
  "proxyErrorLogs": true,
  "inferLogTypes": true,
  "autoDiscovery": true,
  "autoDiscoverySearchDepth": 2,
  "watcherScope": "project",
  "watchExclude": [
    "docs/**",
    "spec/**"
  ],
  "locations": [
    "_test/performance-native",
    "demos/01-container",
    "demos/02-shape",
    "demos/03-drawable",
    "demos/04-graphics",
    "demos/05-controls",
    "demos/06-performance"
  ],
  "logFilter": [
    "app",
    "error"
  ],
  "fileLogs": {
    "enabled": true,
    "outputFile": "love2d.log",
    "logLines": 1000
  }
}