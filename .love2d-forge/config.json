{
  "proxyErrorLogs": true,
  "inferLogTypes": true,
  "autoDiscovery": true,
  "autoDiscoverySearchDepth": 2,
  "watcherScope": "project",
  "locations": [
    "demos/01-container",
    "demos/02-shape",
    "demos/03-drawable"
  ],
  "logFilter": [
    "app"
  ],
  "fileLogs": {
    "enabled": true,
    "outputFile": "love2d.log",
