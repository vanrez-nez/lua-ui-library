{
  "proxyErrorLogs": true,
  "inferLogTypes": true,
  "autoDiscovery": true,
  "autoDiscoverySearchDepth": 2,
  "watcherScope": "project",
  "watchExclude": [
    "docs/**",
    "src/lua/spec/**"
  ],
  "locations": [
    "_test/performance-native",
    "src/lua/demos/01-container",
    "src/lua/demos/02-shape",
    "src/lua/demos/03-drawable",
    "src/lua/demos/04-graphics",
    "src/lua/demos/05-controls",
    "src/lua/demos/06-performance"
  ],
  "logFilter": [
    "app",
    "error"
  ],
  "fileLogs": {
    "enabled": true,
    "outputFile": "love2d.log",
    "logLines": 1000
  }
}
